{
  "name": "mkclue",
  "version": "1.2.0",
  "description": "MKClue - An elegant Markdown editor with folder mapping and image support",
  "author": "Lostiz",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win --x64",
    "electron:build:all": "vite build && electron-builder",
    "electron:preview": "vite build && electron ."
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "katex": "^0.16.9",
    "marked": "^12.0.0",
    "marked-highlight": "^2.1.0",
    "mermaid": "^10.8.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mkclue.editor",
    "productName": "MKClue",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/mkclue.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/mkclue.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/mkclue.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MKClue",
      "deleteAppDataOnUninstall": true,
      "uninstallDisplayName": "MKClue",
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052",
      "perMachine": false,
      "allowElevation": true,
      "installerIcon": "public/mkclue.ico",
      "uninstallerIcon": "public/mkclue.ico",
      "include": "./build/uninstall.nsh"
    }
  }
}
